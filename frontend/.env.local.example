# Copy to .env.local and fill in. NEXT_PUBLIC_* vars are exposed to the browser.

# FastAPI backend (Render in prod, localhost in dev)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_WS_URL=ws://localhost:8000/ws/sensor-stream

# Supabase (ANON key only — never the service-role key here)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
