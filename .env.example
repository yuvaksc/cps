# ════════════════════════════════════════════════════════════════════
#  CT-MIF Production System — environment template
#  Copy to .env and fill in.  NEVER commit the real .env.
# ════════════════════════════════════════════════════════════════════

# ─── Supabase ───────────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
# Backend uses the SERVICE-ROLE key (bypasses RLS, writes readings/events).
SUPABASE_KEY=your-service-role-key
# Frontend uses the ANON key only (exposed to the browser).
SUPABASE_ANON_KEY=your-anon-key

# ─── Groq (agent LLM) ───────────────────────────────────────────────
GROQ_API_KEY=your-groq-key
# Reasoning model for the 4 agents. See https://console.groq.com/docs/models
# (Groq rotates models — swap if this one is deprecated.)
GROQ_MODEL=llama-3.3-70b-versatile

# ─── CT-MIF / Replay ────────────────────────────────────────────────
# Compact test-split replay file (build with scripts/build_replay_data.py).
# Falls back to data/sample_readings.json if this is missing.
ARTIFACTS_DIR=artifacts
REPLAY_DATASET_PATH=data/replay_test.csv.gz
REPLAY_DEFAULT_SPEED=50

# ─── Server ─────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
# Comma-separated origins allowed to call the API (your Vercel URL + local dev)
CORS_ORIGINS=http://localhost:3000

# ─── Optional: agent tracing (LangSmith) ────────────────────────────
LANGSMITH_TRACING_V2=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=cps
