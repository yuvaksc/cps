# ════════════════════════════════════════════════════════════════════
#  CT-MIF — environment template
#  Copy to .env and fill in.  NEVER commit the real .env.
#  Everything here is OPTIONAL: with no .env the app runs fully (agents
#  use the heuristic fallback; SQLite is created automatically).
# ════════════════════════════════════════════════════════════════════

# ─── Database (local SQLite) ────────────────────────────────────────
# Default writes ./ctmif.db next to the app. Override to relocate it.
DATABASE_URL=sqlite:///./ctmif.db

# ─── Groq (agent LLM) ───────────────────────────────────────────────
# Without a key the 4 agents fall back to deterministic heuristics.
GROQ_API_KEY=your-groq-key
# Reasoning model for the agents. See https://console.groq.com/docs/models
GROQ_MODEL=llama-3.3-70b-versatile

# ─── CT-MIF / Replay ────────────────────────────────────────────────
# Compact test-split replay file (build with scripts/build_replay_data.py).
# Falls back to data/sample_readings.json if this is missing.
ARTIFACTS_DIR=artifacts
REPLAY_DATASET_PATH=data/replay_test.csv.gz
REPLAY_DEFAULT_SPEED=50

# ─── Server ─────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
# Origins allowed to call the API. The dashboard's live component calls from a
# sandboxed iframe (origin http://localhost:8501), so "*" is simplest; pin to a
# specific origin in production. (Comma-separated list, or "*".)
CORS_ORIGINS=*

# ─── Dashboard (Streamlit) ──────────────────────────────────────────
# Where the Streamlit app reaches the FastAPI backend.
API_URL=http://localhost:8000
API_WS_URL=ws://localhost:8000/ws/sensor-stream
